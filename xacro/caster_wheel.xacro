<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="barista_bot">

<xacro:macro name="caster_wheel" params="position">
    <link name="${position}_yaw_link">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.0206" radius="0.0352"/>
            </geometry>
            <material name="green_light"/>
        </visual>

        <collision>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>    
            <geometry>
            <cylinder length="0.0206" radius="0.0352"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.01"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0000034512333333" ixy="0" ixz="0" iyy=".0000034512333333" iyz="0" izz="0.0000061952"/>
        </inertial>
    </link>

    <gazebo reference="${position}_yaw_link">
        <material>Gazebo/Green</material>
    </gazebo>

    <link name="${position}_roll_link">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.0206" radius="0.0352"/>
            </geometry>
            <material name="red"/>
        </visual>

        <collision>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
            <cylinder length="0.0206" radius="0.0352"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.01"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0000034512333333" ixy="0" ixz="0" iyy=".0000034512333333" iyz="0" izz="0.0000061952"/>
        </inertial>
    </link>

    <joint name="${position}_yaw_to_roll_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="${position}_yaw_link" />
        <child link="${position}_roll_link" />
        <axis xyz="1 0 0" />
        <limit effort="1000.0" velocity="100.0" />
        <dynamics damping="0.0" friction="0.1"/>
    </joint> 

    <gazebo reference="${position}_roll_link">
        <material>Gazebo/Red</material>
    </gazebo>


    <link name="${position}_pitch_link">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.0352"/>
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <geometry>
            <sphere radius="0.0352"/>
            </geometry>
        </collision>

        <inertial>
        <mass value="0.01"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.00000495616" ixy="0" ixz="0" iyy="0.00000495616" iyz="0" izz="0.00000495616"/>
        </inertial>
    </link>

    <gazebo reference="${position}_pitch_link">
        <kp>1000</kp>
        <kd>100</kd>
        <mu1>0.01</mu1>
        <mu2>0.01</mu2>
        <material>Gazebo/White</material>
    </gazebo>

    <joint name="${position}_roll_to_pitch_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="${position}_roll_link" />
        <child link="${position}_pitch_link" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="100.0" />
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

</xacro:macro>

</robot>